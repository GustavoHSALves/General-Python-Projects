    "import numpy as np\n",
    "from sklearn import metrics\n",
    "\n",
    "# Option 1: Calculate RMSE manually by taking the square root of MSE\n",
    "print('MAE: {}'.format(metrics.mean_absolute_error(test_set['y'].values, y_pred['yhat'].values)))\n",
    "print('RMSE: {}'.format(np.sqrt(metrics.mean_squared_error(test_set['y'].values, y_pred['yhat'].values))))\n",
    "\n",
    "# Option 2: If you want to update scikit-learn to use the squared parameter\n",
    "# pip install --upgrade scikit-learn\n",
    "# Then you can use the original code\n",
    "\n",
    "# MAE (Mean Absolute Error) mede a diferença absoluta média entre os valores previstos e os valores reais.\n",
    "\n",
    "# RMSE (Root Mean Squared Error) mede a raiz quadrada da média dos quadrados das diferenças entre os valores previstos e os valores reais.\n",
    "\n",
    "# Se o RMSE for muito maior que o MAE, significa que seu modelo apresenta grandes erros de previsão em determinados pontos de dados. Se forem próximos, os erros são mais consistentes."
   ]
